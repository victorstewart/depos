NAME lz4
VERSION 1.10.0
SYSTEM_LIBS ALLOW
SOURCE URL https://github.com/lz4/lz4/archive/refs/tags/v1.10.0.tar.gz
SOURCE_SUBDIR build/cmake
BUILD_SYSTEM CMAKE
CMAKE_DEFINE BUILD_SHARED_LIBS=OFF
CMAKE_DEFINE BUILD_STATIC_LIBS=ON
CMAKE_DEFINE LZ4_BUILD_CLI=OFF
CMAKE_DEFINE LZ4_BUILD_LEGACY_LZ4C=OFF
TARGET lz4::lz4 STATIC lib/liblz4.a INTERFACE include

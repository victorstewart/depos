NAME zstd
VERSION 1.5.7
SYSTEM_LIBS ALLOW
SOURCE URL https://github.com/facebook/zstd/archive/refs/tags/v1.5.7.tar.gz
SOURCE_SUBDIR build/cmake
BUILD_SYSTEM CMAKE
CMAKE_DEFINE ZSTD_BUILD_SHARED=OFF
CMAKE_DEFINE ZSTD_BUILD_STATIC=ON
CMAKE_DEFINE ZSTD_BUILD_PROGRAMS=OFF
CMAKE_DEFINE ZSTD_BUILD_TESTS=OFF
CMAKE_DEFINE ZSTD_BUILD_CONTRIB=OFF
CMAKE_DEFINE ZSTD_LEGACY_SUPPORT=OFF
CMAKE_DEFINE ZSTD_MULTITHREAD_SUPPORT=OFF
TARGET zstd::zstd STATIC lib/libzstd.a INTERFACE include
